<?xml version='1.0' encoding='UTF-8'?>
<wave_config>
   <wave_state>
   </wave_state>
   <db_ref_list>
      <db_ref path="tb_debouncer_behav.wdb" id="1">
         <top_modules>
            <top_module name="glbl" />
            <top_module name="tb_debouncer" />
         </top_modules>
      </db_ref>
   </db_ref_list>
   <zoom_setting>
      <ZoomStartTime time="0" />
      <ZoomEndTime time="5100000" />
      <Cursor1Time time="30000" />
   </zoom_setting>
   <column_width_setting>
      <NameColumnWidth column_width="180" />
      <ValueColumnWidth column_width="110" />
   </column_width_setting>
   <WVObjectSize size="5" />
   <wave_markers>
      <marker label="RESET_OFF" time="30000" />
      <marker label="BTN_PRESS" time="40000" />
      <marker label="MID_CHECK" time="2500000" />
      <marker label="BTN_RELEASE" time="5040000" />
      <marker label="DONE" time="5060000" />
   </wave_markers>
   <wvobject type="logic" fp_name="/tb_debouncer/clk">
      <obj_property name="ElementShortName">clk</obj_property>
      <obj_property name="ObjectShortName">clk</obj_property>
      <obj_property name="CustomSignalColor">#D0D0D0</obj_property>
      <obj_property name="UseCustomSignalColor">true</obj_property>
   </wvobject>
   <wvobject type="group" fp_name="capture_group1">
      <obj_property name="label">Button Stabilization</obj_property>
      <obj_property name="DisplayName">label</obj_property>
      <obj_property name="isExpanded" />
      <wvobject type="logic" fp_name="/tb_debouncer/rst">
         <obj_property name="ElementShortName">rst</obj_property>
         <obj_property name="ObjectShortName">rst</obj_property>
         <obj_property name="CustomSignalColor">#D0D0D0</obj_property>
         <obj_property name="UseCustomSignalColor">true</obj_property>
      </wvobject>
      <wvobject type="logic" fp_name="/tb_debouncer/i_btn">
         <obj_property name="ElementShortName">i_btn</obj_property>
         <obj_property name="ObjectShortName">i_btn</obj_property>
         <obj_property name="CustomSignalColor">#F5A623</obj_property>
         <obj_property name="UseCustomSignalColor">true</obj_property>
      </wvobject>
      <wvobject type="logic" fp_name="/tb_debouncer/U0/btn_db_reg">
         <obj_property name="ElementShortName">btn_db_reg</obj_property>
         <obj_property name="ObjectShortName">btn_db_reg</obj_property>
         <obj_property name="CustomSignalColor">#8C8C8C</obj_property>
         <obj_property name="UseCustomSignalColor">true</obj_property>
      </wvobject>
   </wvobject>
   <wvobject type="group" fp_name="capture_group2">
      <obj_property name="label">Hold Counter Progress</obj_property>
      <obj_property name="DisplayName">label</obj_property>
      <obj_property name="isExpanded" />
      <wvobject type="logic" fp_name="/tb_debouncer/i_btn">
         <obj_property name="ElementShortName">i_btn</obj_property>
         <obj_property name="ObjectShortName">i_btn</obj_property>
         <obj_property name="CustomSignalColor">#F5A623</obj_property>
         <obj_property name="UseCustomSignalColor">true</obj_property>
      </wvobject>
      <wvobject type="array" fp_name="/tb_debouncer/U0/hold_count_reg">
         <obj_property name="ElementShortName">hold_count_reg[31:0]</obj_property>
         <obj_property name="ObjectShortName">hold_count_reg[31:0]</obj_property>
         <obj_property name="Radix">UNSIGNEDDECRADIX</obj_property>
         <obj_property name="CustomSignalColor">#8C8C8C</obj_property>
         <obj_property name="UseCustomSignalColor">true</obj_property>
      </wvobject>
      <wvobject type="logic" fp_name="/tb_debouncer/U0/hold_fired_reg">
         <obj_property name="ElementShortName">hold_fired_reg</obj_property>
         <obj_property name="ObjectShortName">hold_fired_reg</obj_property>
         <obj_property name="CustomSignalColor">#8C8C8C</obj_property>
         <obj_property name="UseCustomSignalColor">true</obj_property>
      </wvobject>
      <wvobject type="logic" fp_name="/tb_debouncer/o_btn_hold">
         <obj_property name="ElementShortName">o_btn_hold</obj_property>
         <obj_property name="ObjectShortName">o_btn_hold</obj_property>
         <obj_property name="CustomSignalColor">#1F8F85</obj_property>
         <obj_property name="UseCustomSignalColor">true</obj_property>
      </wvobject>
   </wvobject>
   <wvobject type="group" fp_name="capture_group3">
      <obj_property name="label">Short Pulse After Release</obj_property>
      <obj_property name="DisplayName">label</obj_property>
      <obj_property name="isExpanded" />
      <wvobject type="logic" fp_name="/tb_debouncer/i_btn">
         <obj_property name="ElementShortName">i_btn</obj_property>
         <obj_property name="ObjectShortName">i_btn</obj_property>
         <obj_property name="CustomSignalColor">#F5A623</obj_property>
         <obj_property name="UseCustomSignalColor">true</obj_property>
      </wvobject>
      <wvobject type="logic" fp_name="/tb_debouncer/o_btn">
         <obj_property name="ElementShortName">o_btn</obj_property>
         <obj_property name="ObjectShortName">o_btn</obj_property>
         <obj_property name="CustomSignalColor">#2CB1A6</obj_property>
         <obj_property name="UseCustomSignalColor">true</obj_property>
      </wvobject>
      <wvobject type="logic" fp_name="/tb_debouncer/o_btn_hold">
         <obj_property name="ElementShortName">o_btn_hold</obj_property>
         <obj_property name="ObjectShortName">o_btn_hold</obj_property>
         <obj_property name="CustomSignalColor">#1F8F85</obj_property>
         <obj_property name="UseCustomSignalColor">true</obj_property>
      </wvobject>
   </wvobject>
</wave_config>
