<?xml version='1.0' encoding='UTF-8'?>
<wave_config>
   <wave_state>
   </wave_state>
   <db_ref_list>
      <db_ref path="tb_timer_datapath_behav.wdb" id="1">
         <top_modules>
            <top_module name="glbl" />
            <top_module name="tb_timer_datapath" />
         </top_modules>
      </db_ref>
   </db_ref_list>
   <zoom_setting>
      <ZoomStartTime time="0" />
      <ZoomEndTime time="220000000" />
      <Cursor1Time time="30000" />
   </zoom_setting>
   <column_width_setting>
      <NameColumnWidth column_width="190" />
      <ValueColumnWidth column_width="110" />
   </column_width_setting>
   <WVObjectSize size="5" />
   <wave_markers>
      <marker label="RESET_OFF" time="30000" />
      <marker label="RUN_START" time="50000" />
      <marker label="CLEAR_ON" time="100000030000" />
      <marker label="DOWN_MODE" time="111000030000" />
      <marker label="DONE" time="211000030000" />
   </wave_markers>
   <wvobject type="logic" fp_name="/tb_timer_datapath/clk">
      <obj_property name="ElementShortName">clk</obj_property>
      <obj_property name="ObjectShortName">clk</obj_property>
      <obj_property name="CustomSignalColor">#D0D0D0</obj_property>
      <obj_property name="UseCustomSignalColor">true</obj_property>
   </wvobject>
   <wvobject type="group" fp_name="capture_group1">
      <obj_property name="label">Up Count After Run Start</obj_property>
      <obj_property name="DisplayName">label</obj_property>
      <obj_property name="isExpanded" />
      <wvobject type="logic" fp_name="/tb_timer_datapath/rst">
         <obj_property name="ElementShortName">rst</obj_property>
         <obj_property name="ObjectShortName">rst</obj_property>
