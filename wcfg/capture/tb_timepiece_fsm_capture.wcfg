<?xml version='1.0' encoding='UTF-8'?>
<wave_config>
   <wave_state>
   </wave_state>
   <db_ref_list>
      <db_ref path="tb_timepiece_fsm_behav.wdb" id="1">
         <top_modules>
            <top_module name="glbl" />
            <top_module name="tb_timepiece_fsm" />
         </top_modules>
      </db_ref>
   </db_ref_list>
   <zoom_setting>
      <ZoomStartTime time="25000" />
      <ZoomEndTime time="180000" />
      <Cursor1Time time="30000" />
   </zoom_setting>
   <column_width_setting>
      <NameColumnWidth column_width="180" />
      <ValueColumnWidth column_width="110" />
   </column_width_setting>
   <WVObjectSize size="5" />
   <wave_markers>
      <marker label="RESET_OFF" time="30000" />
      <marker label="SET_ENTER" time="55000" />
      <marker label="INDEX_SHIFT_DONE" time="75000" />
      <marker label="INC_DONE" time="95000" />
      <marker label="INC_TENS_DONE" time="115000" />
      <marker label="DEC_DONE" time="135000" />
      <marker label="DEC_TENS_DONE" time="155000" />
      <marker label="SET_EXIT_DONE" time="165000" />
      <marker label="SW0_FORCE_VIEW" time="215000" />
   </wave_markers>
