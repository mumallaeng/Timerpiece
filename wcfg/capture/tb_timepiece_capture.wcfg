<?xml version='1.0' encoding='UTF-8'?>
<wave_config>
   <wave_state>
   </wave_state>
   <db_ref_list>
      <db_ref path="tb_timepiece_behav.wdb" id="1">
         <top_modules>
            <top_module name="glbl" />
            <top_module name="tb_timepiece" />
         </top_modules>
      </db_ref>
   </db_ref_list>
   <zoom_setting>
      <ZoomStartTime time="25000" />
      <ZoomEndTime time="12700000" />
      <Cursor1Time time="30000" />
   </zoom_setting>
   <column_width_setting>
      <NameColumnWidth column_width="180" />
      <ValueColumnWidth column_width="110" />
   </column_width_setting>
   <WVObjectSize size="5" />
   <wave_markers>
      <marker label="RESET_OFF" time="30000" />
      <marker label="MSEC_TEN_DONE" time="1055000" />
      <marker label="SEC_ONE_DONE" time="10055000" />
      <marker label="SET_HOLD_DONE" time="12045000" />
      <marker label="FORMAT_TOGGLE_DONE" time="12055000" />
      <marker label="EDIT_DONE" time="12125000" />
      <marker label="APPLY_SET" time="12145000" />
      <marker label="DONE" time="12645000" />
   </wave_markers>
   <wvobject type="logic" fp_name="/tb_timepiece/clk">
      <obj_property name="ElementShortName">clk</obj_property>
      <obj_property name="ObjectShortName">clk</obj_property>
      <obj_property name="CustomSignalColor">#D0D0D0</obj_property>
      <obj_property name="UseCustomSignalColor">true</obj_property>
   </wvobject>
   <wvobject type="group" fp_name="capture_group1">
