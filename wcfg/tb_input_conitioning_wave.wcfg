<?xml version="1.0" encoding="UTF-8"?>
<wave_config>
   <wave_state>
   </wave_state>
   <db_ref_list>
      <db_ref path="tb_input_conitioning_behav.wdb" id="1">
         <top_modules>
            <top_module name="glbl" />
            <top_module name="tb_input_conitioning" />
         </top_modules>
      </db_ref>
   </db_ref_list>
   <zoom_setting>
      <ZoomStartTime time="0"></ZoomStartTime>
      <ZoomEndTime time="5010100000"></ZoomEndTime>
      <Cursor1Time time="30000"></Cursor1Time>
   </zoom_setting>
   <column_width_setting>
      <NameColumnWidth column_width="180"></NameColumnWidth>
      <ValueColumnWidth column_width="110"></ValueColumnWidth>
   </column_width_setting>
   <WVObjectSize size="5" />
   <wave_markers>
      <marker label="RESET_OFF" time="30000" />
      <marker label="BUTTON_PRESS" time="40000" />
      <marker label="HOLD_WINDOW" time="1000040000" />
      <marker label="BUTTON_RELEASE" time="5000040000" />
      <marker label="SWITCH_CHANGE" time="5000100000" />
   </wave_markers>
   <wvobject type="logic" fp_name="/tb_input_conitioning/clk">
      <obj_property name="ElementShortName">clk</obj_property>
      <obj_property name="ObjectShortName">clk</obj_property>
      <obj_property name="CustomSignalColor">#DCDCDC</obj_property>
      <obj_property name="UseCustomSignalColor">true</obj_property>
   </wvobject>
   <wvobject type="group" fp_name="group1">
      <obj_property name="label">Input</obj_property>
